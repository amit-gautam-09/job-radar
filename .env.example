# Copy to .env and fill in. .env is gitignored — never commit real tokens.
# See PLAN.md §Human Checklist for how to obtain these.

# Telegram (required for notifications; pipeline runs without it in dry-run/regex mode)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: enables the AI scoring layer. Omit to run in regex-only mode (fully functional).
# A Claude Code subscription does NOT provide API credits — this is a separate key from
# console.anthropic.com with prepaid credit.
ANTHROPIC_API_KEY=
